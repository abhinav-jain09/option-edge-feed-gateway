# Feed-gateway DEV runtime environment (template — copy to /Users/abhinav/ci/config/feed-gateway.env,
# which the feed-gateway-deploy Jenkins job sources at launch; kept out of git).
#
# Dev runs on the local Mac. Uniform gateway port 8093 (Docker Desktop owns 8091). The WS auth issuer MUST
# be the Mac LAN IP — the option-chain web app runs in a container and issues tokens with iss=<LAN-IP>:8089,
# and the gateway validates the exact iss (a localhost issuer rejects the handshake with close 4001).

APP_WEB_PORT=8093

# WebSocket JWT auth (Keycloak).
WS_AUTH_ENABLED=true
WS_AUTH_ISSUER_URI=http://192.168.100.102:8089/realms/optionsedge
WS_AUTH_AUDIENCE=options-edge-web
WS_ALLOWED_ORIGINS=http://localhost:8090

# Live data source — local dev Kafka + Schema Registry.
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=192.168.100.102:9092
KAFKA_SCHEMA_REGISTRY_URL=http://192.168.100.102:8082

# Per-session historical replay (Live<->Replay). The gateway authorizes runId ownership against the
# replay orchestrator before turning a runId into topic reads, so a user cannot stream another user's run
# (P0 — runId authz). Required whenever DATABENTO_REPLAY_UI_ENABLED=true, else startup is refused.
DATABENTO_REPLAY_UI_ENABLED=true
# Point at the orchestrator's own SERVER_PORT (server-to-server, NOT the UI's same-origin route). Replace
# host:port per environment — see hpsf-replay-orchestrator-service deploy/REPLAY-ROUTING.md (e.g. :8095/:8103).
GATEWAY_REPLAY_ORCHESTRATOR_URL=http://<orchestrator-host>:<SERVER_PORT>
# GATEWAY_REPLAY_ORCHESTRATOR_TIMEOUT_MS=3000
# Max wall-clock a replay read may go WITHOUT progress before it is reported REPLAY_INCOMPLETE
# (empty polls are retried until here; a stall short of the captured target offsets fails, never
# silently completes). Reset on every polled record / partition reaching target.
# GATEWAY_REPLAY_IDLE_TIMEOUT_MS=30000
# Replay concurrency + cancellation (P0 — generation barrier). Each start/stop/return-to-live
# cancels the prior reader (wakes its consumer, awaits termination) and bumps a generation that
# gates all output, so a stale poll batch or late terminal status can never reach the UI.
# GATEWAY_REPLAY_MAX_CONCURRENT=16        # max simultaneous replay readers; further starts -> 409
# GATEWAY_REPLAY_SHUTDOWN_AWAIT_MS=2000   # how long a control call awaits the prior reader exiting

# Slow-client isolation (P0). The Kafka consumer never writes to a socket directly; each socket has a
# bounded, coalescing outbound queue drained by a dedicated writer. A slow/blocked/adversarial client only
# fills its OWN queue and is disconnected when a limit is exceeded — it can never stall Kafka polling.
# GATEWAY_WS_MAX_QUEUED_MESSAGES=1000   # max buffered messages per socket before disconnect
# GATEWAY_WS_MAX_QUEUED_BYTES=16777216  # max buffered bytes per socket before disconnect
# GATEWAY_WS_WRITE_DEADLINE_MS=5000     # a send stuck longer than this force-closes that client
# GATEWAY_WS_WRITER_THREADS=8           # shared outbound writer pool size

# Approval enforcement (P0). A valid token is NOT approval (the realm allows public self-registration).
# The gateway consults an authoritative approval record before any data access AND re-checks it during
# sessions; default-deny. Configure EXACTLY ONE source (startup refuses if neither is set):
# GATEWAY_APPROVAL_ROLE=oe-approved        # dev/simple: an admin-granted realm role (NOT a default role)
# GATEWAY_APPROVAL_URL=http://approvals:8099  # prod: Config-Control platform (GET /api/approvals/{userId})
# GATEWAY_APPROVAL_API_KEY=...             # optional shared secret sent to the approval platform
# GATEWAY_APPROVAL_RECHECK_MS=60000        # how often active sessions are re-checked for revocation

# Session lifecycle enforcement (P0). Entitlements are refreshed from every verified token, and active
# sessions are periodically revalidated (approval + roles) and swept for idle/max-session expiry; affected
# sockets are force-closed on revocation, disablement, idle timeout, or max-session deadline.
# GATEWAY_SESSION_EXPIRY_SWEEP_MS=30000   # how often idle/max-session expiry is swept
# GATEWAY_APPROVAL_RECHECK_MS=60000       # how often approval + entitlements are revalidated (see above)

# Multi-replica safety (P1). Tickets are stamped with this replica's id and the WS handshake rejects a
# ticket minted by another replica — so the WS upgrade MUST be sticky-routed to the minting replica (see
# MULTI-REPLICA.md). Defaults to the hostname/pod name; set explicitly for a stable id (k8s: pod name).
# GATEWAY_INSTANCE_ID=feed-gateway-0
