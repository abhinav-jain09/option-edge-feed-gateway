# Feed-gateway PRODUCTION runtime environment (template — copy to a real, out-of-git env file/secret).
#
# The gateway consumes the final display topics from Kafka and broadcasts them to browsers over an
# authenticated WebSocket. It is an OAuth2 resource server for the WS handshake: it validates the same
# Keycloak tokens the option-chain web app mints. DEV ONLY differences: dev uses the Mac LAN-IP issuer and
# http; prod uses the real HTTPS Keycloak issuer behind TLS.

# Uniform gateway port across dev and prod. (Dev can't use 8091 — Docker Desktop owns it on the Mac.)
APP_WEB_PORT=8093

# --- WebSocket JWT auth (Keycloak) ---
# WS_AUTH_ISSUER_URI MUST equal the option-chain web app's VITE_AUTH_ISSUER and the token's `iss`, or the
# handshake is rejected (close 4001). Audience binds the token to this surface. Origins is the EXACT prod
# UI origin(s) — never `*` in prod.
WS_AUTH_ENABLED=true
WS_AUTH_ISSUER_URI=https://keycloak.internal/realms/optionsedge
WS_AUTH_AUDIENCE=options-edge-web
WS_ALLOWED_ORIGINS=https://options-edge.example.com

# --- Live data source (Kafka) ---
# Prod consumes the final display topics. Kafka/Schema Registry stay private (browsers never touch Kafka).
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=kafka-1.prod.internal:9092
KAFKA_SCHEMA_REGISTRY_URL=http://schema-registry.prod.internal:8082

# --- Per-session historical replay (runId ownership authz) ---
# When replay is enabled, the gateway calls the orchestrator's ownership-checked run endpoint with the
# caller's bearer BEFORE reading any *.replay.<runId>.* topic — owning the WS session does not prove
# ownership of the run. GATEWAY_REPLAY_ORCHESTRATOR_URL is mandatory whenever DATABENTO_REPLAY_UI_ENABLED
# is true (startup is refused otherwise). Replay is also disabled in prod unless DATABENTO_REPLAY_ALLOW_PROD=true.
DATABENTO_REPLAY_UI_ENABLED=false
GATEWAY_REPLAY_ORCHESTRATOR_URL=https://hpsf-replay-orchestrator.prod.internal
# GATEWAY_REPLAY_ORCHESTRATOR_TIMEOUT_MS=3000
